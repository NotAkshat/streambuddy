# Copy this file to .env.local or set the variables in your shell.
# Do NOT commit real keys. This is an example with placeholders.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# Optional: set a TURN server or ICE servers (recommended for NAT traversal)
# VITE_ICE_SERVERS='[{"urls":["stun:stun.l.google.com:19302"]}]'
# or
# VITE_TURN_URL="turn:your.turn.server:3478"
# VITE_TURN_USERNAME="username"
# VITE_TURN_PASSWORD="password"

# For local server-only operations (DO NOT expose service role key to clients):
# SUPABASE_SERVICE_ROLE_KEY="<service-role-key>" # server only

# Usage: duplicate to a .env.local (gitignored) or set in your environment before running the dev server.
# Example: export VITE_SUPABASE_URL=... && export VITE_SUPABASE_ANON_KEY=... && npm run dev
